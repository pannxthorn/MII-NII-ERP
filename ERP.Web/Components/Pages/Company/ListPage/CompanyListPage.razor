@page "/company"
@rendermode InteractiveServer
@using ERP.Web.Services
@using ERP.ApplicationDTO.company
@using ERP.Web.Components.Shared
@inject CompanyService CompanyService
@inject NavigationManager Navigation

<PageTitle>Company Management</PageTitle>

<MainListPage TItem="CompanyDTO"
              Title="Company Management"
              Description="Manage your company information and settings"
              Items="@companies"
              IsLoading="@isLoading"
              ErrorMessage="@errorMessage"
              EmptyStateTitle="No companies found"
              EmptyStateDescription="Get started by creating your first company."
              ShowSearch="true"
              SearchPlaceholder="Search..."
              ShowRefreshButton="true"
              CreateButtonText="Add Company"
              OnRefresh="LoadCompanies"
              SearchFilter="@SearchCompanyFilter">

    <TableHeader>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
            Company Code
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
            Company Name
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
            Tax Number
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
            Contact
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
            Status
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
            Actions
        </th>
    </TableHeader>

    <TableRow Context="company">
        <tr class="hover:bg-gray-50 transition-colors duration-150">
            <td class="px-4 py-3 whitespace-nowrap">
                <div class="flex items-center gap-3">
                    <div class="flex-shrink-0 h-8 w-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center">
                        <span class="text-white text-xs font-bold">@company.CompanyCode.Substring(0, Math.Min(2, company.CompanyCode.Length)).ToUpper()</span>
                    </div>
                    <div class="text-sm font-medium text-gray-900">@company.CompanyCode</div>
                </div>
            </td>
            <td class="px-4 py-3">
                <div class="text-sm font-medium text-gray-900">@company.CompanyName</div>
                @if (!string.IsNullOrEmpty(company.Email))
                {
                    <div class="text-xs text-gray-500">@company.Email</div>
                }
            </td>
            <td class="px-4 py-3 whitespace-nowrap">
                <div class="text-sm text-gray-900">@(company.TaxNo ?? "-")</div>
            </td>
            <td class="px-4 py-3 whitespace-nowrap">
                @if (!string.IsNullOrEmpty(company.Phone))
                {
                    <div class="text-sm text-gray-900">@company.Phone</div>
                }
                else
                {
                    <span class="text-sm text-gray-500">-</span>
                }
            </td>
            <td class="px-4 py-3 whitespace-nowrap">
                <StatusBadge IsActive="@company.IsActive" IsDeleted="@company.IsDelete" />
            </td>
            <td class="px-4 py-3 whitespace-nowrap">
                <ActionButtons
                    OnView="() => ViewCompany(company.CompanyId)"
                    OnEdit="() => EditCompany(company.CompanyId)"
                    OnDelete="() => DeleteCompany(company.CompanyId)" />
            </td>
        </tr>
    </TableRow>

</MainListPage>

@code {
    private List<CompanyDTO>? companies;
    private bool isLoading = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCompanies();
    }

    private async Task LoadCompanies()
    {
        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var response = await CompanyService.GetAllCompanyAsync();

            if (response.IsSuccess && response.Data != null)
            {
                companies = response.Data;
            }
            else
            {
                errorMessage = response.Message ?? "Failed to load companies.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private bool SearchCompanyFilter(CompanyDTO company, string searchText)
    {
        if (string.IsNullOrWhiteSpace(searchText))
            return true;

        searchText = searchText.ToLower();

        return company.CompanyCode.ToLower().Contains(searchText) ||
               company.CompanyName.ToLower().Contains(searchText) ||
               (company.TaxNo != null && company.TaxNo.ToLower().Contains(searchText)) ||
               (company.Email != null && company.Email.ToLower().Contains(searchText)) ||
               (company.Phone != null && company.Phone.ToLower().Contains(searchText));
    }

    private void ViewCompany(string companyId)
    {
        Navigation.NavigateTo($"/company/{companyId}");
    }

    private void EditCompany(string companyId)
    {
        Navigation.NavigateTo($"/company/edit/{companyId}");
    }

    private void DeleteCompany(string companyId)
    {
        // TODO: Implement delete functionality with confirmation dialog
    }
}
