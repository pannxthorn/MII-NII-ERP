@page "/company/create"
@page "/company/edit/{Id}"
@page "/company/view/{Id}"
@rendermode InteractiveServer
@using ERP.Web.Services
@using ERP.ApplicationDTO.company
@using ERP.ApplicationDTO.branch
@using ERP.Web.Components.Shared
@using static ERP.Web.Components.Shared.CrudPage
@inject CompanyService CompanyService
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>@GetPageTitle()</PageTitle>

<CrudPage @key="@($"{currentMode}-{Id}")"
          Mode="@currentMode"
          Title="@GetTitle()"
          Description="@GetDescription()"
          IsLoading="@isLoading"
          ErrorMessage="@errorMessage"
          OnSave="HandleSubmit"
          OnCancel="HandleCancel"
          OnEdit="HandleEdit"
          OnDelete="HandleDelete"
          BackUrl="/company"
          Tabs="@tabs"
          ActiveTab="@activeTab"
          OnTabChanged="HandleTabChanged">

    @if (currentMode == CrudMode.View)
    {
        <!-- View Mode with Tabs -->
        @if (activeTab == "general")
        {
            <CrudSection Title="Basic Information"
                        Description="Company basic details and contact information"
                        Icon="building"
                        GradientFrom="blue"
                        GradientTo="indigo">
                <CrudField Label="Company Code" @bind-Value="model.CompanyCode" />
                <CrudField Label="Company Name" @bind-Value="model.CompanyName" />
                <CrudField Label="Tax Number" @bind-Value="model.TaxNo" />
                <CrudField Label="Phone" @bind-Value="model.Phone" />
                <CrudField Label="Email" @bind-Value="model.Email" IsLink="true" />
                <CrudField Label="Website" @bind-Value="model.Website" IsLink="true" />
                <CrudField Label="Comment" @bind-Value="model.Comment" IsFullWidth="true" />
            </CrudSection>

            <CrudSection Title="Status & Settings"
                        Icon="clipboard"
                        GradientFrom="purple"
                        GradientTo="pink">
                <CrudField Label="Status" @bind-Value="model.IsActive" Type="checkbox" IsBadge="true">
                    <CustomViewContent>
                        <span class="@GetStatusBadgeClass()">
                            @(model.IsActive && !model.IsDelete ? "Active" : "Inactive")
                        </span>
                    </CustomViewContent>
                </CrudField>
                <CrudField Label="Total Branches" Value="@(model.BranchDTOs?.Count().ToString() ?? "0")" />
            </CrudSection>

            <CrudSection Title="Audit Information"
                        Description="Record creation and modification details"
                        Icon="document"
                        GradientFrom="gray"
                        GradientTo="slate">
                <CrudField Label="Created Date" Value="@model.Creation_Date.ToString("dd MMM yyyy HH:mm")" />
                <CrudField Label="Created By" @bind-Value="model.Created_By_Id" />
                <CrudField Label="Last Updated" Value="@model.Last_Update_By_Date.ToString("dd MMM yyyy HH:mm")" />
                <CrudField Label="Updated By" @bind-Value="model.Last_Update_By_Id" />
            </CrudSection>
        }
        else if (activeTab == "branches")
        {
            <CrudSection Title="Branch Locations"
                        Description="All branches under this company"
                        Icon="location"
                        GradientFrom="orange"
                        GradientTo="red"
                        Layout="custom">
                <HeaderActions>
                    <button class="px-3 py-1.5 bg-white/20 backdrop-blur-sm hover:bg-white/30 text-white text-sm font-semibold rounded-lg transition-all flex items-center gap-2 shadow-lg">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                        Add Branch
                    </button>
                </HeaderActions>
                <ChildContent>
                    @if (model.BranchDTOs != null && model.BranchDTOs.Any())
                    {
                        <div class="divide-y divide-gray-200">
                            @foreach (var branch in model.BranchDTOs)
                            {
                                <div class="py-4 hover:bg-gray-50 transition-colors px-4 -mx-4 rounded-lg">
                                    <div class="flex items-start justify-between">
                                        <div class="flex-1">
                                            <div class="flex items-center gap-3 mb-2">
                                                <div class="flex-shrink-0 h-10 w-10 bg-gradient-to-br from-orange-500 to-red-600 rounded-lg flex items-center justify-center">
                                                    <span class="text-white text-sm font-bold">@branch.BranchCode.Substring(0, Math.Min(2, branch.BranchCode.Length)).ToUpper()</span>
                                                </div>
                                                <div>
                                                    <h4 class="text-base font-semibold text-gray-900">@branch.BranchName</h4>
                                                    <p class="text-sm text-gray-600">@branch.BranchCode</p>
                                                </div>
                                                @if (branch.IsHeadQuarter)
                                                {
                                                    <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded-full text-xs font-medium">HQ</span>
                                                }
                                            </div>
                                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 ml-13">
                                                @if (!string.IsNullOrEmpty(branch.Phone))
                                                {
                                                    <div class="flex items-center gap-2 text-sm text-gray-600">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                                                        </svg>
                                                        @branch.Phone
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(branch.Email))
                                                {
                                                    <div class="flex items-center gap-2 text-sm text-gray-600">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                                        </svg>
                                                        @branch.Email
                                                    </div>
                                                }
                                                <div class="flex items-center gap-2 text-sm">
                                                    <span class="@(branch.IsActive && !branch.IsDelete ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800") px-2 py-1 rounded-full text-xs font-medium">
                                                        @(branch.IsActive && !branch.IsDelete ? "Active" : "Inactive")
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-2 ml-4">
                                            <button class="p-2 text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                                </svg>
                                            </button>
                                            <button class="p-2 text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-8 text-gray-500">
                            <svg class="mx-auto h-12 w-12 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                            </svg>
                            <p class="text-sm">No branches found</p>
                        </div>
                    }
                </ChildContent>
            </CrudSection>
        }
        else if (activeTab == "activity")
        {
            <CrudSection Title="Activity History"
                        Description="Recent changes and activities"
                        Icon="clipboard"
                        GradientFrom="green"
                        GradientTo="teal"
                        Layout="custom">
                <div class="text-center py-8 text-gray-500">
                    <svg class="mx-auto h-12 w-12 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                    </svg>
                    <p class="text-sm">Activity log coming soon</p>
                </div>
            </CrudSection>
        }
    }
    else
    {
        <!-- Create/Edit Mode -->
        <CrudSection Title="Company Information"
                    Description="Basic details and identification"
                    Icon="building"
                    GradientFrom="blue"
                    GradientTo="indigo">
            <CrudField Label="Company Code" @bind-Value="createModel.CompanyCode" Required MaxLength="50" Placeholder="COM001" />
            <CrudField Label="Company Name" @bind-Value="createModel.CompanyName" Required MaxLength="300" Placeholder="Acme Corporation" />
            <CrudField Label="Tax Number" @bind-Value="createModel.TaxNo" MaxLength="13" Placeholder="0-1234-56789-01-2" IsFullWidth="true" />
        </CrudSection>

        <CrudSection Title="Contact Information"
                    Description="How to reach your company"
                    Icon="mail"
                    GradientFrom="emerald"
                    GradientTo="teal">
            <CrudField Label="Phone" @bind-Value="createModel.Phone" Type="tel" MaxLength="100" Placeholder="02-123-4567" />
            <CrudField Label="Email" @bind-Value="createModel.Email" Type="email" MaxLength="100" Placeholder="contact@company.com" />
            <CrudField Label="Website" @bind-Value="createModel.Website" Type="url" MaxLength="300" Placeholder="https://www.company.com" IsFullWidth="true" />
        </CrudSection>

        <CrudSection Title="Additional Notes"
                    Description="Any other information"
                    Icon="note"
                    GradientFrom="purple"
                    GradientTo="pink">
            <CrudField Label="Comments" @bind-Value="createModel.Comment" Type="textarea" Rows="4" MaxLength="4000" Placeholder="Enter any additional information..." IsFullWidth="true" />
        </CrudSection>

        <CrudSection Title="Branch Locations"
                    Description="At least one branch is required"
                    Icon="location"
                    GradientFrom="orange"
                    GradientTo="red"
                    Layout="custom">
            <HeaderActions>
                <button type="button"
                        @onclick="AddBranch"
                        class="px-4 py-2 bg-white/20 backdrop-blur-sm hover:bg-white/30 text-white text-sm font-semibold rounded-lg transition-all flex items-center gap-2 shadow-lg">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Add Branch
                </button>
            </HeaderActions>
            <ChildContent>
                @if (createModel.BranchDTOs != null && createModel.BranchDTOs.Any())
                {
                    var branches = createModel.BranchDTOs.ToList();
                    <div class="space-y-4">
                        @for (int i = 0; i < branches.Count; i++)
                        {
                            var index = i;
                            var branch = branches[index];

                            <div class="bg-gradient-to-br from-gray-50 to-blue-50 border-2 border-gray-200 rounded-xl p-5 hover:border-blue-300 hover:shadow-md transition-all">
                                <div class="flex items-center justify-between mb-4">
                                    <div class="flex items-center gap-3">
                                        <div class="flex items-center justify-center w-10 h-10 bg-gradient-to-br from-orange-500 to-red-600 text-white text-sm font-bold rounded-lg shadow-md">
                                            @(index + 1)
                                        </div>
                                        <div>
                                            <h3 class="text-base font-bold text-gray-900">Branch @(index + 1)</h3>
                                            <p class="text-xs text-gray-600">Location details</p>
                                        </div>
                                    </div>
                                    @if (branches.Count > 1)
                                    {
                                        <button type="button"
                                                @onclick="() => RemoveBranch(index)"
                                                class="px-3 py-1.5 bg-red-100 hover:bg-red-200 text-red-700 text-sm font-medium rounded-lg transition-colors flex items-center gap-1.5">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                            </svg>
                                            Remove
                                        </button>
                                    }
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                            Branch Code <span class="text-red-500">*</span>
                                        </label>
                                        <input type="text"
                                               @bind="branch.BranchCode"
                                               required
                                               maxlength="50"
                                               class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-white"
                                               placeholder="BR001" />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                            Branch Name <span class="text-red-500">*</span>
                                        </label>
                                        <input type="text"
                                               @bind="branch.BranchName"
                                               required
                                               maxlength="300"
                                               class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-white"
                                               placeholder="Head Office" />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                            Phone Number
                                        </label>
                                        <input type="tel"
                                               @bind="branch.Phone"
                                               maxlength="100"
                                               class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-white"
                                               placeholder="02-xxx-xxxx" />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                            Email Address
                                        </label>
                                        <input type="email"
                                               @bind="branch.Email"
                                               maxlength="100"
                                               class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-white"
                                               placeholder="branch@company.com" />
                                    </div>
                                </div>

                                <div class="flex items-center pt-2 mt-3">
                                    <label class="flex items-center cursor-pointer group">
                                        <input type="checkbox"
                                               @bind="branch.IsHeadQuarter"
                                               class="w-4 h-4 text-orange-600 border-gray-300 rounded focus:ring-orange-500 focus:ring-2" />
                                        <span class="ml-2 text-sm font-medium text-gray-700 group-hover:text-gray-900">This is the head office</span>
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-12 bg-gradient-to-br from-gray-50 to-orange-50 rounded-lg border-2 border-dashed border-gray-300">
                        <svg class="mx-auto h-12 w-12 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <p class="text-sm font-medium text-gray-700">No branches added yet</p>
                        <p class="text-xs text-gray-500 mt-1">Click "Add Branch" to get started</p>
                    </div>
                }
            </ChildContent>
        </CrudSection>
    }

</CrudPage>

@code {
    [Parameter] public string? Id { get; set; }

    private CrudMode currentMode = CrudMode.Create;
    private CrudMode previousMode = CrudMode.Create;
    private string? previousId;
    private CreateCompanyDTO createModel = new();
    private CompanyDTO model = new();
    private bool isLoading = false;
    private string errorMessage = string.Empty;
    private string activeTab = "general";

    private List<TabItem> tabs = new()
    {
        new TabItem { Id = "general", Label = "General" },
        new TabItem { Id = "branches", Label = "Branches" },
        new TabItem { Id = "activity", Label = "Activity" }
    };

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to navigation changes
        Navigation.LocationChanged += HandleLocationChanged;
        await InitializeComponent();
    }

    protected override async Task OnParametersSetAsync()
    {
        await InitializeComponent();
    }

    private async void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        await InitializeComponent();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        // Unsubscribe from navigation changes
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private async Task InitializeComponent()
    {
        DetermineMode();

        // Check if mode or id changed to avoid unnecessary reloads
        bool modeChanged = currentMode != previousMode;
        bool idChanged = Id != previousId;

        if (!modeChanged && !idChanged)
            return;

        // Update tracking variables
        previousMode = currentMode;
        previousId = Id;

        // Reset state
        errorMessage = string.Empty;
        activeTab = "general"; // Reset to default tab

        if (currentMode == CrudMode.Create)
        {
            // Initialize with one empty branch
            createModel = new CreateCompanyDTO();
            createModel.BranchDTOs = new List<CreateBranchDTO> { new CreateBranchDTO() };
        }
        else if (currentMode == CrudMode.View || currentMode == CrudMode.Edit)
        {
            await LoadCompanyInfo();
        }

        // Force UI update
        StateHasChanged();
    }

    private void DetermineMode()
    {
        var uri = Navigation.Uri;
        var oldMode = currentMode;

        if (uri.Contains("/company/create"))
            currentMode = CrudMode.Create;
        else if (uri.Contains("/company/edit/"))
            currentMode = CrudMode.Edit;
        else if (uri.Contains("/company/view/"))
            currentMode = CrudMode.View;

        // Debug log
        Console.WriteLine($"[CompanyPage] URI: {uri}");
        Console.WriteLine($"[CompanyPage] Mode changed from {oldMode} to {currentMode}");
        Console.WriteLine($"[CompanyPage] Id: {Id}");
    }

    private async Task LoadCompanyInfo()
    {
        if (string.IsNullOrEmpty(Id)) return;

        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var response = await CompanyService.GetCompanyByIdAsync(Id);

            if (response.IsSuccess && response.Data != null)
            {
                model = response.Data;

                if (currentMode == CrudMode.Edit)
                {
                    // Convert to CreateCompanyDTO for editing
                    createModel = new CreateCompanyDTO
                    {
                        CompanyCode = model.CompanyCode,
                        CompanyName = model.CompanyName,
                        TaxNo = model.TaxNo,
                        Phone = model.Phone,
                        Email = model.Email,
                        Website = model.Website,
                        Comment = model.Comment,
                        BranchDTOs = model.BranchDTOs?.Select(b => new CreateBranchDTO
                        {
                            BranchCode = b.BranchCode,
                            BranchName = b.BranchName,
                            Phone = b.Phone,
                            Email = b.Email,
                            IsHeadQuarter = b.IsHeadQuarter
                        }).ToList() ?? new List<CreateBranchDTO>()
                    };
                }
            }
            else
            {
                errorMessage = response.Message ?? "Failed to load company information.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleSubmit()
    {
        if (!ValidateForm())
            return;

        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            if (currentMode == CrudMode.Create)
            {
                var response = await CompanyService.CreateCompanyAsync(createModel);

                if (response.IsSuccess && response.Data != null)
                {
                    Navigation.NavigateTo($"/company/view/{response.Data.CompanyId}");
                }
                else
                {
                    errorMessage = response.Message ?? "Failed to create company.";
                }
            }
            else if (currentMode == CrudMode.Edit)
            {
                // TODO: Implement update API
                errorMessage = "Update functionality coming soon.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private bool ValidateForm()
    {
        if (string.IsNullOrWhiteSpace(createModel.CompanyCode))
        {
            errorMessage = "Company Code is required.";
            return false;
        }

        if (string.IsNullOrWhiteSpace(createModel.CompanyName))
        {
            errorMessage = "Company Name is required.";
            return false;
        }

        if (createModel.BranchDTOs == null || !createModel.BranchDTOs.Any())
        {
            errorMessage = "At least one branch is required.";
            return false;
        }

        foreach (var branch in createModel.BranchDTOs)
        {
            if (string.IsNullOrWhiteSpace(branch.BranchCode))
            {
                errorMessage = "All branches must have a Branch Code.";
                return false;
            }

            if (string.IsNullOrWhiteSpace(branch.BranchName))
            {
                errorMessage = "All branches must have a Branch Name.";
                return false;
            }
        }

        return true;
    }

    private void HandleCancel()
    {
        Navigation.NavigateTo("/company");
    }

    private void HandleEdit()
    {
        if (!string.IsNullOrEmpty(Id))
        {
            // Try without forceLoad first
            Navigation.NavigateTo($"/company/edit/{Id}");
        }
    }

    private void HandleDelete()
    {
        // TODO: Implement delete with confirmation
    }

    private void HandleTabChanged(string tabId)
    {
        activeTab = tabId;
        StateHasChanged();
    }

    private void AddBranch()
    {
        var branches = createModel.BranchDTOs?.ToList() ?? new List<CreateBranchDTO>();
        branches.Add(new CreateBranchDTO());
        createModel.BranchDTOs = branches;
        StateHasChanged();
    }

    private void RemoveBranch(int index)
    {
        if (createModel.BranchDTOs != null && createModel.BranchDTOs.Count() > 1)
        {
            var branches = createModel.BranchDTOs.ToList();
            branches.RemoveAt(index);
            createModel.BranchDTOs = branches;
            StateHasChanged();
        }
    }

    private string GetPageTitle()
    {
        return currentMode switch
        {
            CrudMode.Create => "Create Company",
            CrudMode.Edit => $"Edit {model.CompanyName ?? "Company"}",
            CrudMode.View => model.CompanyName ?? "Company Information",
            _ => "Company"
        };
    }

    private string GetTitle()
    {
        return currentMode switch
        {
            CrudMode.Create => "Company",
            CrudMode.Edit => model.CompanyName ?? "Company",
            CrudMode.View => model.CompanyName ?? "Company",
            _ => "Company"
        };
    }

    private string GetDescription()
    {
        return currentMode switch
        {
            CrudMode.Create => "Fill in the required information to add a new company",
            CrudMode.Edit => model.CompanyCode ?? "",
            CrudMode.View => model.CompanyCode ?? "",
            _ => ""
        };
    }

    private string GetStatusBadgeClass()
    {
        return model.IsActive && !model.IsDelete
            ? "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800"
            : "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800";
    }
}
