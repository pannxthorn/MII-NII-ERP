@page "/company/view/{CompanyId}"
@rendermode InteractiveServer
@using ERP.Web.Services
@using ERP.ApplicationDTO.company
@using ERP.Web.Components.Shared
@using static ERP.Web.Components.Shared.MainInfoPage
@inject CompanyService CompanyService
@inject NavigationManager Navigation

<PageTitle>Company Info - @(company?.CompanyName ?? "Loading...")</PageTitle>

<MainInfoPage Title="@GetTitle()"
              Description="@GetDescription()"
              Subtitle="@GetSubtitle()"
              IsLoading="@isLoading"
              ErrorMessage="@errorMessage"
              ShowBackButton="true"
              BackUrl="/company"
              OnBack="@(() => Navigation.NavigateTo("/company"))"
              ShowRefreshButton="true"
              OnRefresh="LoadCompanyInfo"
              OnEdit="HandleEdit"
              OnDelete="HandleDelete"
              Tabs="@tabs"
              ActiveTab="@activeTab"
              OnTabChanged="HandleTabChanged">

    @if (company != null)
    {
        @if (activeTab == "general")
        {
            <!-- General Information Tab -->
            <InfoSection Title="Basic Information"
                        Description="Company basic details and contact information">
                <ChildContent>
                    <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <InfoField Label="Company Code" Value="@company.CompanyCode" />
                        <InfoField Label="Company Name" Value="@company.CompanyName" />
                        <InfoField Label="Tax Number" Value="@company.TaxNo" />
                        <InfoField Label="Phone" Value="@company.Phone" />
                        <InfoField Label="Fax" Value="@company.Fax" />
                        <InfoField Label="Email" Value="@company.Email" IsLink="true" LinkUrl="@($"mailto:{company.Email}")" />
                        <InfoField Label="Website" Value="@company.Website" IsLink="true" LinkUrl="@company.Website" />
                        <InfoField Label="Comment" Value="@company.Comment" IsFullWidth="true" />
                    </dl>
                </ChildContent>
            </InfoSection>

            <InfoSection Title="Status & Settings">
                <ChildContent>
                    <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <InfoField Label="Status" IsBadge="true" BadgeClass="@GetStatusBadgeClass()">
                            <CustomContent>
                                <span class="@GetStatusBadgeClass()">
                                    @(company.IsActive && !company.IsDelete ? "Active" : "Inactive")
                                </span>
                            </CustomContent>
                        </InfoField>
                        <InfoField Label="Total Branches" Value="@(company.BranchDTOs?.Count().ToString() ?? "0")" />
                    </dl>
                </ChildContent>
            </InfoSection>

            <!-- Audit Information -->
            <InfoSection Title="Audit Information"
                        Description="Record creation and modification details">
                <ChildContent>
                    <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <InfoField Label="Created Date" Value="@company.Creation_Date.ToString("dd MMM yyyy HH:mm")" />
                        <InfoField Label="Created By" Value="@company.Created_By_Id" />
                        <InfoField Label="Last Updated" Value="@company.Last_Update_By_Date.ToString("dd MMM yyyy HH:mm")" />
                        <InfoField Label="Updated By" Value="@company.Last_Update_By_Id" />
                    </dl>
                </ChildContent>
            </InfoSection>
        }
        else if (activeTab == "branches")
        {
            <!-- Branches Tab -->
            <InfoSection Title="Branch Locations"
                        Description="All branches under this company">
                <HeaderActions>
                    <button class="px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-sm rounded-lg transition-colors flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                        Add Branch
                    </button>
                </HeaderActions>
                <ChildContent>
                    @if (company.BranchDTOs != null && company.BranchDTOs.Any())
                {
                    <div class="divide-y divide-gray-200">
                        @foreach (var branch in company.BranchDTOs)
                        {
                            <div class="py-4 hover:bg-gray-50 transition-colors px-4 -mx-4 rounded-lg">
                                <div class="flex items-start justify-between">
                                    <div class="flex-1">
                                        <div class="flex items-center gap-3 mb-2">
                                            <div class="flex-shrink-0 h-10 w-10 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-lg flex items-center justify-center">
                                                <span class="text-white text-sm font-bold">@branch.BranchCode.Substring(0, Math.Min(2, branch.BranchCode.Length)).ToUpper()</span>
                                            </div>
                                            <div>
                                                <h4 class="text-base font-semibold text-gray-900">@branch.BranchName</h4>
                                                <p class="text-sm text-gray-600">@branch.BranchCode</p>
                                            </div>
                                        </div>
                                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 ml-13">
                                            @if (!string.IsNullOrEmpty(branch.Phone))
                                            {
                                                <div class="flex items-center gap-2 text-sm text-gray-600">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                                                    </svg>
                                                    @branch.Phone
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(branch.Email))
                                            {
                                                <div class="flex items-center gap-2 text-sm text-gray-600">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                                    </svg>
                                                    @branch.Email
                                                </div>
                                            }
                                            <div class="flex items-center gap-2 text-sm">
                                                <span class="@(branch.IsActive && !branch.IsDelete ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800") px-2 py-1 rounded-full text-xs font-medium">
                                                    @(branch.IsActive && !branch.IsDelete ? "Active" : "Inactive")
                                                </span>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(branch.Comment))
                                        {
                                            <p class="text-sm text-gray-600 mt-2 ml-13">@branch.Comment</p>
                                        }
                                    </div>
                                    <div class="flex items-center gap-2 ml-4">
                                        <button class="p-2 text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                            </svg>
                                        </button>
                                        <button class="p-2 text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                    {
                        <div class="text-center py-8 text-gray-500">
                            <svg class="mx-auto h-12 w-12 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                            </svg>
                            <p class="text-sm">No branches found</p>
                        </div>
                    }
                </ChildContent>
            </InfoSection>
        }
        else if (activeTab == "activity")
        {
            <!-- Activity Log Tab -->
            <InfoSection Title="Activity History"
                        Description="Recent changes and activities">
                <ChildContent>
                    <div class="text-center py-8 text-gray-500">
                        <svg class="mx-auto h-12 w-12 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                        </svg>
                        <p class="text-sm">Activity log coming soon</p>
                    </div>
                </ChildContent>
            </InfoSection>
        }
    }

</MainInfoPage>

@code {
    [Parameter] public string CompanyId { get; set; } = string.Empty;

    private CompanyDTO? company;
    private bool isLoading = false;
    private string errorMessage = string.Empty;
    private string activeTab = "general";

    private List<TabItem> tabs = new()
    {
        new TabItem { Id = "general", Label = "General" },
        new TabItem { Id = "branches", Label = "Branches" },
        new TabItem { Id = "activity", Label = "Activity" }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadCompanyInfo();
    }

    private async Task LoadCompanyInfo()
    {
        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var response = await CompanyService.GetCompanyByIdAsync(CompanyId);

            if (response.IsSuccess && response.Data != null)
            {
                company = response.Data;
            }
            else
            {
                errorMessage = response.Message ?? "Failed to load company information.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void HandleEdit()
    {
        Navigation.NavigateTo($"/company/edit/{CompanyId}");
    }

    private void HandleDelete()
    {
        // TODO: Implement delete with confirmation dialog
    }

    private void HandleTabChanged(string tabId)
    {
        activeTab = tabId;
        StateHasChanged();
    }

    private string GetTitle()
    {
        return company?.CompanyName ?? "Company Information";
    }

    private string GetDescription()
    {
        return company?.CompanyCode ?? "Loading...";
    }

    private string GetSubtitle()
    {
        if (company == null) return string.Empty;
        return $"Last updated: {company.Last_Update_By_Date:dd MMM yyyy HH:mm}";
    }

    private string GetStatusBadgeClass()
    {
        if (company == null) return "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800";

        return company.IsActive && !company.IsDelete
            ? "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800"
            : "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800";
    }
}
