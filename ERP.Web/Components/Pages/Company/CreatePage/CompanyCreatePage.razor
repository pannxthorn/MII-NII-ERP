@page "/company/create"
@rendermode InteractiveServer
@using ERP.Web.Services
@using ERP.ApplicationDTO.company
@using ERP.ApplicationDTO.branch
@using ERP.Web.Components.Shared
@inject CompanyService CompanyService
@inject NavigationManager Navigation

<PageTitle>Create Company</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-gray-50 to-blue-50 py-6 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
        <!-- Header -->
        <div class="mb-6">
            <div class="flex items-center justify-between gap-3 mb-4">
                <div class="flex-1">
                    <h1 class="text-3xl font-bold bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">
                        Create New Company
                    </h1>
                    <p class="text-sm text-gray-600 mt-1">Fill in the required information to add a new company</p>
                </div>
                <div class="flex items-center gap-3">
                    <button type="button"
                            @onclick="Cancel"
                            class="px-6 py-2.5 border-2 border-gray-300 text-gray-700 font-semibold rounded-lg hover:bg-gray-50 hover:border-gray-400 transition-all shadow-sm">
                        Cancel
                    </button>
                    <button type="submit"
                            form="companyForm"
                            disabled="@isLoading"
                            class="px-8 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-bold rounded-lg transition-all shadow-lg hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2">
                        @if (isLoading)
                        {
                            <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span>Creating...</span>
                        }
                        else
                        {
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                            <span>Create Company</span>
                        }
                    </button>
                </div>
            </div>
        </div>

        <!-- Error Message -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mb-6 bg-red-50 border border-red-200 rounded-lg p-4">
                <div class="flex gap-3">
                    <svg class="w-5 h-5 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div>
                        <p class="text-sm font-medium text-red-800">Error</p>
                        <p class="text-sm text-red-700 mt-0.5">@errorMessage</p>
                    </div>
                </div>
            </div>
        }

        <!-- Loading Overlay -->
        @if (isLoading)
        {
            <div class="fixed inset-0 bg-gray-900/50 z-50 flex items-center justify-center">
                <div class="bg-white rounded-lg p-8 shadow-xl max-w-sm mx-4">
                    <div class="flex flex-col items-center gap-4">
                        <div class="animate-spin rounded-full h-12 w-12 border-4 border-gray-200 border-t-blue-600"></div>
                        <div class="text-center">
                            <p class="text-base font-medium text-gray-900">Creating Company</p>
                            <p class="text-sm text-gray-600 mt-1">Please wait...</p>
                        </div>
                    </div>
                </div>
            </div>
        }

    <form id="companyForm" @onsubmit="HandleSubmit" class="space-y-5">
        <!-- Company Information Card -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
            <!-- Section Header with Gradient -->
            <div class="bg-gradient-to-r from-blue-500 to-indigo-600 px-6 py-4">
                <div class="flex items-center gap-3">
                    <div class="flex-shrink-0 bg-white/20 backdrop-blur-sm p-2 rounded-lg">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-lg font-bold text-white">Company Information</h2>
                        <p class="text-sm text-blue-100 mt-0.5">Basic details and identification</p>
                    </div>
                </div>
            </div>

            <!-- Form Fields -->
            <div class="p-6 space-y-4">
                <!-- Row 1: Company Code & Name -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="companyCode" class="block text-sm font-medium text-gray-700 mb-1.5">
                            Company Code <span class="text-red-500">*</span>
                        </label>
                        <input type="text"
                               id="companyCode"
                               @bind="model.CompanyCode"
                               required
                               maxlength="50"
                               class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                               placeholder="COM001" />
                    </div>

                    <div>
                        <label for="companyName" class="block text-sm font-medium text-gray-700 mb-1.5">
                            Company Name <span class="text-red-500">*</span>
                        </label>
                        <input type="text"
                               id="companyName"
                               @bind="model.CompanyName"
                               required
                               maxlength="300"
                               class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                               placeholder="Acme Corporation" />
                    </div>
                </div>

                <!-- Row 2: Tax Number -->
                <div>
                    <label for="taxNo" class="block text-sm font-medium text-gray-700 mb-1.5">
                        Tax Identification Number
                    </label>
                    <input type="text"
                           id="taxNo"
                           @bind="model.TaxNo"
                           maxlength="13"
                           class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                           placeholder="0-1234-56789-01-2" />
                </div>
            </div>
        </div>

        <!-- Contact Information Card -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
            <!-- Section Header with Gradient -->
            <div class="bg-gradient-to-r from-emerald-500 to-teal-600 px-6 py-4">
                <div class="flex items-center gap-3">
                    <div class="flex-shrink-0 bg-white/20 backdrop-blur-sm p-2 rounded-lg">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-lg font-bold text-white">Contact Information</h2>
                        <p class="text-sm text-emerald-100 mt-0.5">How to reach your company</p>
                    </div>
                </div>
            </div>

            <!-- Form Fields -->
            <div class="p-6 space-y-4">
                <!-- Row 1: Phone & Email -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">
                            Phone Number
                        </label>
                        <input type="tel"
                               id="phone"
                               @bind="model.Phone"
                               maxlength="100"
                               class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-colors"
                               placeholder="02-123-4567" />
                    </div>

                    <div>
                        <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
                            Email Address
                        </label>
                        <input type="email"
                               id="email"
                               @bind="model.Email"
                               maxlength="100"
                               class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-colors"
                               placeholder="contact@company.com" />
                    </div>
                </div>

                <!-- Row 2: Website -->
                <div>
                    <label for="website" class="block text-sm font-medium text-gray-700 mb-1.5">
                        Website
                    </label>
                    <input type="url"
                           id="website"
                           @bind="model.Website"
                           maxlength="300"
                           class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-colors"
                           placeholder="https://www.company.com" />
                </div>
            </div>
        </div>

        <!-- Additional Notes Card -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
            <!-- Section Header with Gradient -->
            <div class="bg-gradient-to-r from-purple-500 to-pink-600 px-6 py-4">
                <div class="flex items-center gap-3">
                    <div class="flex-shrink-0 bg-white/20 backdrop-blur-sm p-2 rounded-lg">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-lg font-bold text-white">Additional Notes</h2>
                        <p class="text-sm text-purple-100 mt-0.5">Any other information</p>
                    </div>
                </div>
            </div>

            <!-- Form Fields -->
            <div class="p-6">
                <div>
                    <label for="comment" class="block text-sm font-medium text-gray-700 mb-1.5">
                        Comments
                    </label>
                    <textarea id="comment"
                              @bind="model.Comment"
                              rows="4"
                              maxlength="4000"
                              class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-colors resize-none"
                              placeholder="Enter any additional information or notes about this company..."></textarea>
                </div>
            </div>
        </div>

        <!-- Branch Locations Card -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
            <!-- Section Header with Gradient -->
            <div class="bg-gradient-to-r from-orange-500 to-red-600 px-6 py-4">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <div class="flex-shrink-0 bg-white/20 backdrop-blur-sm p-2 rounded-lg">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-lg font-bold text-white">Branch Locations</h2>
                            <p class="text-sm text-orange-100 mt-0.5">At least one branch is required</p>
                        </div>
                    </div>
                    <button type="button"
                            @onclick="AddBranch"
                            class="px-4 py-2 bg-white/20 backdrop-blur-sm hover:bg-white/30 text-white text-sm font-semibold rounded-lg transition-all flex items-center gap-2 shadow-lg">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                        Add Branch
                    </button>
                </div>
            </div>

            <!-- Branch List -->
            <div class="p-6">
                @if (model.BranchDTOs != null && model.BranchDTOs.Any())
                {
                    var branches = model.BranchDTOs.ToList();
                    <div class="space-y-4">
                        @for (int i = 0; i < branches.Count; i++)
                        {
                            var index = i;
                            var branch = branches[index];

                            <div class="bg-gradient-to-br from-gray-50 to-blue-50 border-2 border-gray-200 rounded-xl p-5 hover:border-blue-300 hover:shadow-md transition-all">
                                <!-- Branch Header -->
                                <div class="flex items-center justify-between mb-4">
                                    <div class="flex items-center gap-3">
                                        <div class="flex items-center justify-center w-10 h-10 bg-gradient-to-br from-orange-500 to-red-600 text-white text-sm font-bold rounded-lg shadow-md">
                                            @(index + 1)
                                        </div>
                                        <div>
                                            <h3 class="text-base font-bold text-gray-900">Branch @(index + 1)</h3>
                                            <p class="text-xs text-gray-600">Location details</p>
                                        </div>
                                    </div>
                                    @if (branches.Count > 1)
                                    {
                                        <button type="button"
                                                @onclick="() => RemoveBranch(index)"
                                                class="px-3 py-1.5 bg-red-100 hover:bg-red-200 text-red-700 text-sm font-medium rounded-lg transition-colors flex items-center gap-1.5">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                            </svg>
                                            Remove
                                        </button>
                                    }
                                </div>

                                <!-- Branch Fields -->
                                <div class="space-y-3">
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                                Branch Code <span class="text-red-500">*</span>
                                            </label>
                                            <input type="text"
                                                   @bind="branch.BranchCode"
                                                   required
                                                   maxlength="50"
                                                   class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-white"
                                                   placeholder="BR001" />
                                        </div>

                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                                Branch Name <span class="text-red-500">*</span>
                                            </label>
                                            <input type="text"
                                                   @bind="branch.BranchName"
                                                   required
                                                   maxlength="300"
                                                   class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-white"
                                                   placeholder="Head Office" />
                                        </div>

                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                                Phone Number
                                            </label>
                                            <input type="tel"
                                                   @bind="branch.Phone"
                                                   maxlength="100"
                                                   class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-white"
                                                   placeholder="02-xxx-xxxx" />
                                        </div>

                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                                Email Address
                                            </label>
                                            <input type="email"
                                                   @bind="branch.Email"
                                                   maxlength="100"
                                                   class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors bg-white"
                                                   placeholder="branch@company.com" />
                                        </div>
                                    </div>

                                    <div class="flex items-center pt-2">
                                        <label class="flex items-center cursor-pointer group">
                                            <input type="checkbox"
                                                   @bind="branch.IsHeadQuarter"
                                                   class="w-4 h-4 text-orange-600 border-gray-300 rounded focus:ring-orange-500 focus:ring-2" />
                                            <span class="ml-2 text-sm font-medium text-gray-700 group-hover:text-gray-900">This is the head office</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-12 bg-gradient-to-br from-gray-50 to-orange-50 rounded-lg border-2 border-dashed border-gray-300">
                        <svg class="mx-auto h-12 w-12 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <p class="text-sm font-medium text-gray-700">No branches added yet</p>
                        <p class="text-xs text-gray-500 mt-1">Click "Add Branch" to get started</p>
                    </div>
                }
            </div>
        </div>
    </form>
    </div>
</div>

@code {
    private CreateCompanyDTO model = new();
    private bool isLoading = false;
    private string errorMessage = string.Empty;

    protected override void OnInitialized()
    {
        // Initialize with one empty branch
        var branches = new List<CreateBranchDTO>
        {
            new CreateBranchDTO()
        };
        model.BranchDTOs = branches;
    }

    private void AddBranch()
    {
        var branches = model.BranchDTOs?.ToList() ?? new List<CreateBranchDTO>();
        branches.Add(new CreateBranchDTO());
        model.BranchDTOs = branches;
        StateHasChanged();
    }

    private void RemoveBranch(int index)
    {
        if (model.BranchDTOs != null && model.BranchDTOs.Count() > 1)
        {
            var branches = model.BranchDTOs.ToList();
            branches.RemoveAt(index);
            model.BranchDTOs = branches;
            StateHasChanged();
        }
    }

    private async Task HandleSubmit()
    {
        if (!ValidateForm())
            return;

        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var response = await CompanyService.CreateCompanyAsync(model);

            if (response.IsSuccess && response.Data != null)
            {
                // Navigate to the created company's info page
                Navigation.NavigateTo($"/company/view/{response.Data.CompanyId}");
            }
            else
            {
                errorMessage = response.Message ?? "Failed to create company.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private bool ValidateForm()
    {
        if (string.IsNullOrWhiteSpace(model.CompanyCode))
        {
            errorMessage = "Company Code is required.";
            return false;
        }

        if (string.IsNullOrWhiteSpace(model.CompanyName))
        {
            errorMessage = "Company Name is required.";
            return false;
        }

        if (model.BranchDTOs == null || !model.BranchDTOs.Any())
        {
            errorMessage = "At least one branch is required.";
            return false;
        }

        foreach (var branch in model.BranchDTOs)
        {
            if (string.IsNullOrWhiteSpace(branch.BranchCode))
            {
                errorMessage = "All branches must have a Branch Code.";
                return false;
            }

            if (string.IsNullOrWhiteSpace(branch.BranchName))
            {
                errorMessage = "All branches must have a Branch Name.";
                return false;
            }
        }

        return true;
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/company");
    }
}
