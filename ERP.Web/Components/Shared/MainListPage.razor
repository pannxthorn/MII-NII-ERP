@typeparam TItem

<div class="w-full">
    <!-- Header Section -->
    <div class="mb-4">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
            <!-- Title and Description -->
            <div>
                <h2 class="text-xl font-bold text-gray-900">@Title</h2>
                @if (!string.IsNullOrEmpty(Description))
                {
                    <p class="text-xs text-gray-600 mt-0.5">@Description</p>
                }
            </div>

            <!-- Action Buttons -->
            <div class="flex items-center gap-2">
                @if (ShowRefreshButton)
                {
                    <button @onclick="HandleRefresh"
                            disabled="@IsLoading"
                            class="px-3 py-2 bg-white border border-gray-300 hover:bg-gray-50 rounded-lg text-sm font-medium text-gray-700 transition-all duration-200 flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                        <svg class="w-4 h-4 @(IsLoading ? "animate-spin" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                        </svg>
                        <span class="hidden sm:inline">Refresh</span>
                    </button>
                }
                @if (CreateButton.HasDelegate)
                {
                    <button @onclick="HandleCreate"
                            class="px-3 py-2 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-lg text-sm font-medium transition-all duration-200 flex items-center gap-2 shadow-md hover:shadow-lg">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                        <span>@CreateButtonText</span>
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Search and Filter Section -->
    @if (ShowSearch)
    {
        <div class="mb-4">
            <div class="relative max-w-md">
                <div class="absolute top-1/2 -translate-y-1/2 left-3 pointer-events-none">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>
                <input type="text"
                       @bind="searchText"
                       @bind:event="oninput"
                       @onkeyup="HandleSearch"
                       placeholder="@SearchPlaceholder"
                       class="block w-full pl-10 pr-3 py-2 text-sm border border-gray-300 rounded-lg bg-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200" />
            </div>
        </div>
    }

    <!-- Error Message -->
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-3 py-2 rounded-lg flex items-start gap-2">
            <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="text-xs">@ErrorMessage</span>
        </div>
    }

    <!-- Loading State -->
    @if (IsLoading)
    {
        <div class="flex items-center justify-center py-8">
            <div class="text-center">
                <div class="inline-block animate-spin rounded-full h-10 w-10 border-4 border-gray-200 border-t-blue-600"></div>
                <p class="mt-3 text-xs text-gray-600">Loading data...</p>
            </div>
        </div>
    }
    else if (FilteredItems == null || !FilteredItems.Any())
    {
        <!-- Empty State -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 py-8">
            <div class="text-center">
                <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                </svg>
                <h3 class="mt-3 text-sm font-medium text-gray-900">@EmptyStateTitle</h3>
                <p class="mt-1 text-xs text-gray-500">@EmptyStateDescription</p>
            </div>
        </div>
    }
    else
    {
        <!-- Data Table -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            @TableHeader
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var item in FilteredItems)
                        {
                            @TableRow(item)
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination (Optional - can be added later) -->
            <div class="bg-gray-50 px-4 py-2 border-t border-gray-200">
                <div class="flex items-center justify-between">
                    <div class="text-xs text-gray-600">
                        Showing <span class="font-medium">@FilteredItems.Count()</span> results
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // Required Parameters
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public RenderFragment TableHeader { get; set; } = default!;
    [Parameter, EditorRequired] public RenderFragment<TItem> TableRow { get; set; } = default!;
    [Parameter] public IEnumerable<TItem>? Items { get; set; }

    // Optional Parameters
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string EmptyStateTitle { get; set; } = "No data found";
    [Parameter] public string EmptyStateDescription { get; set; } = "Get started by creating a new item.";
    [Parameter] public bool ShowSearch { get; set; } = true;
    [Parameter] public string SearchPlaceholder { get; set; } = "Search...";
    [Parameter] public bool ShowRefreshButton { get; set; } = true;
    [Parameter] public string CreateButtonText { get; set; } = "Create New";
    [Parameter] public bool IsLoading { get; set; } = false;
    [Parameter] public string ErrorMessage { get; set; } = string.Empty;

    // Events
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback CreateButton { get; set; }
    [Parameter] public Func<TItem, string, bool>? SearchFilter { get; set; }

    // Private Fields
    private string searchText = string.Empty;
    private IEnumerable<TItem>? FilteredItems => GetFilteredItems();

    private IEnumerable<TItem>? GetFilteredItems()
    {
        if (Items == null)
            return null;

        if (string.IsNullOrWhiteSpace(searchText) || SearchFilter == null)
            return Items;

        return Items.Where(item => SearchFilter(item, searchText));
    }

    private async Task HandleRefresh()
    {
        if (OnRefresh.HasDelegate)
        {
            await OnRefresh.InvokeAsync();
        }
    }

    private async Task HandleCreate()
    {
        if (CreateButton.HasDelegate)
        {
            await CreateButton.InvokeAsync();
        }
    }

    private void HandleSearch()
    {
        // Trigger re-render by accessing FilteredItems
        StateHasChanged();
    }
}
