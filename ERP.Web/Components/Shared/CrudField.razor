@typeparam TValue
@*
    CrudField - Smart field component that auto-switches between input/readonly based on mode
    Usage:
    <CrudField Label="Company Name" @bind-Value="model.CompanyName" Required />
    <CrudField Label="Email" @bind-Value="model.Email" Type="email" />
    <CrudField Label="Comment" @bind-Value="model.Comment" Type="textarea" Rows="4" />
*@

<div class="@GetContainerClass()">
    <label class="block text-sm font-medium text-gray-700 mb-1.5">
        @Label
        @if (Required && IsEditMode())
        {
            <span class="text-red-500">*</span>
        }
    </label>

    @if (IsEditMode())
    {
        <!-- Edit Mode: Show Input -->
        @if (Type == "textarea")
        {
            <textarea @bind="CurrentValue"
                      @bind:event="oninput"
                      rows="@Rows"
                      required="@Required"
                      maxlength="@MaxLength"
                      placeholder="@Placeholder"
                      disabled="@Disabled"
                      class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors resize-none"
                      style="@(IsFullWidth ? "grid-column: 1 / -1;" : "")">@CurrentValue</textarea>
        }
        else if (Type == "checkbox")
        {
            <div class="flex items-center pt-2">
                <input type="checkbox"
                       @bind="CurrentValueBool"
                       disabled="@Disabled"
                       class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 focus:ring-2" />
            </div>
        }
        else if (Type == "select" && Options != null)
        {
            <select @bind="CurrentValue"
                    required="@Required"
                    disabled="@Disabled"
                    class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                <option value="">-- Select @Label --</option>
                @foreach (var option in Options)
                {
                    <option value="@option.Value">@option.Text</option>
                }
            </select>
        }
        else
        {
            <input type="@Type"
                   @bind="CurrentValue"
                   @bind:event="oninput"
                   required="@Required"
                   maxlength="@MaxLength"
                   placeholder="@Placeholder"
                   disabled="@Disabled"
                   class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                   style="@(IsFullWidth ? "grid-column: 1 / -1;" : "")" />
        }
    }
    else
    {
        <!-- View Mode: Show Read-Only -->
        <div class="mt-1">
            @if (CustomViewContent != null)
            {
                @CustomViewContent
            }
            else if (Type == "checkbox")
            {
                <span class="@(CurrentValueBool ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800") inline-flex items-center px-3 py-1 rounded-full text-sm font-medium">
                    @(CurrentValueBool ? "Yes" : "No")
                </span>
            }
            else if (IsLink && !string.IsNullOrEmpty(CurrentValueString))
            {
                <a href="@(LinkUrl ?? CurrentValueString)" target="_blank" class="text-blue-600 hover:text-blue-800 hover:underline text-sm">
                    @CurrentValueString
                </a>
            }
            else if (IsBadge)
            {
                <span class="@BadgeClass">
                    @CurrentValueString
                </span>
            }
            else
            {
                <p class="text-sm text-gray-900 whitespace-pre-wrap">
                    @(string.IsNullOrEmpty(CurrentValueString) ? EmptyText : CurrentValueString)
                </p>
            }
        </div>
    }
</div>

@code {
    [CascadingParameter] public CrudPage? CrudPage { get; set; }

    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public TValue? Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }
    [Parameter] public string Type { get; set; } = "text"; // text, email, tel, url, number, date, textarea, checkbox, select
    [Parameter] public bool Required { get; set; }
    [Parameter] public int MaxLength { get; set; }
    [Parameter] public string Placeholder { get; set; } = string.Empty;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public int Rows { get; set; } = 3;
    [Parameter] public bool IsFullWidth { get; set; }
    [Parameter] public bool IsLink { get; set; }
    [Parameter] public string? LinkUrl { get; set; }
    [Parameter] public bool IsBadge { get; set; }
    [Parameter] public string BadgeClass { get; set; } = "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800";
    [Parameter] public string EmptyText { get; set; } = "-";
    [Parameter] public List<SelectOption>? Options { get; set; }
    [Parameter] public RenderFragment? CustomViewContent { get; set; }

    private TValue? CurrentValue
    {
        get => Value;
        set
        {
            if (!EqualityComparer<TValue>.Default.Equals(value, Value))
            {
                Value = value;
                ValueChanged.InvokeAsync(value);
            }
        }
    }

    private bool CurrentValueBool
    {
        get
        {
            if (Value is bool boolValue)
                return boolValue;
            return false;
        }
        set
        {
            if (Value is bool)
            {
                CurrentValue = (TValue)(object)value;
            }
        }
    }

    private string CurrentValueString
    {
        get
        {
            if (Value == null) return string.Empty;
            if (Value is string strValue) return strValue;
            if (Value is DateTime dateValue) return dateValue.ToString("dd MMM yyyy");
            return Value.ToString() ?? string.Empty;
        }
    }

    private bool IsEditMode()
    {
        if (CrudPage == null) return true; // Default to edit if no CrudPage context
        return CrudPage.Mode == CrudPage.CrudMode.Create || CrudPage.Mode == CrudPage.CrudMode.Edit;
    }

    private string GetContainerClass()
    {
        if (IsFullWidth)
        {
            return "col-span-full";
        }
        return "";
    }

    public class SelectOption
    {
        public string Value { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
    }
}
