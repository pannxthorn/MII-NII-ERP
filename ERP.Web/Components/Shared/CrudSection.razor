@*
    CrudSection - Section wrapper with gradient header
    Usage:
    <CrudSection Title="Basic Information"
                 Description="Company details"
                 Icon="building"
                 GradientFrom="blue"
                 GradientTo="indigo">
        <CrudField Label="Name" @bind-Value="model.Name" />
    </CrudSection>
*@

<div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
    <!-- Section Header with Gradient -->
    <div class="@GetHeaderGradientClass() px-6 py-4">
        <div class="flex items-center @(HeaderActions != null ? "justify-between" : "gap-3")">
            <div class="flex items-center gap-3">
                @if (!string.IsNullOrEmpty(Icon))
                {
                    <div class="flex-shrink-0 bg-white/20 backdrop-blur-sm p-2 rounded-lg">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            @((MarkupString)GetIconPath())
                        </svg>
                    </div>
                }
                <div>
                    <h2 class="text-lg font-bold text-white">@Title</h2>
                    @if (!string.IsNullOrEmpty(Description))
                    {
                        <p class="text-sm @GetDescriptionColorClass() mt-0.5">@Description</p>
                    }
                </div>
            </div>
            @if (HeaderActions != null)
            {
                <div>
                    @HeaderActions
                </div>
            }
        </div>
    </div>

    <!-- Section Body -->
    <div class="p-6">
        @if (ChildContent != null)
        {
            <div class="@GetBodyLayoutClass()">
                @ChildContent
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = "document";
    [Parameter] public string GradientFrom { get; set; } = "blue";
    [Parameter] public string GradientTo { get; set; } = "indigo";
    [Parameter] public string Layout { get; set; } = "grid"; // grid, stack, custom
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? HeaderActions { get; set; }

    private string GetHeaderGradientClass()
    {
        return $"bg-gradient-to-r from-{GradientFrom}-500 to-{GradientTo}-600";
    }

    private string GetDescriptionColorClass()
    {
        return $"text-{GradientFrom}-100";
    }

    private string GetBodyLayoutClass()
    {
        return Layout switch
        {
            "grid" => "grid grid-cols-1 md:grid-cols-2 gap-4",
            "stack" => "space-y-4",
            "custom" => "",
            _ => "grid grid-cols-1 md:grid-cols-2 gap-4"
        };
    }

    private string GetIconPath()
    {
        return Icon.ToLower() switch
        {
            "building" => @"<path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4""></path>",
            "mail" => @"<path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z""></path>",
            "note" => @"<path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z""></path>",
            "location" => @"<path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z""></path><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M15 11a3 3 0 11-6 0 3 3 0 016 0z""></path>",
            "user" => @"<path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z""></path>",
            "document" => @"<path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z""></path>",
            "clipboard" => @"<path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2""></path>",
            _ => @"<path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z""></path>"
        };
    }
}
