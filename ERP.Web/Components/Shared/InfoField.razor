<!-- Reusable Field Display Component -->
<div class="@(IsFullWidth ? "col-span-2" : "col-span-1")">
    <dt class="text-sm font-medium text-gray-600 mb-1">@Label</dt>
    <dd class="@ValueClass">
        @if (!string.IsNullOrEmpty(Value))
        {
            @if (IsLink && !string.IsNullOrEmpty(LinkUrl))
            {
                <a href="@LinkUrl" class="text-blue-600 hover:text-blue-800 hover:underline transition-colors">
                    @Value
                </a>
            }
            else if (IsBadge)
            {
                <span class="@BadgeClass">
                    @Value
                </span>
            }
            else
            {
                @Value
            }
        }
        else if (CustomContent != null)
        {
            @CustomContent
        }
        else
        {
            <span class="text-gray-400">-</span>
        }
    </dd>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Value { get; set; }
    [Parameter] public string ValueClass { get; set; } = "text-base text-gray-900";
    [Parameter] public bool IsFullWidth { get; set; } = false;

    // Link Support
    [Parameter] public bool IsLink { get; set; } = false;
    [Parameter] public string? LinkUrl { get; set; }

    // Badge Support
    [Parameter] public bool IsBadge { get; set; } = false;
    [Parameter] public string BadgeClass { get; set; } = "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800";

    // Custom Content
    [Parameter] public RenderFragment? CustomContent { get; set; }
}
