@inject NavigationManager Navigation

<div class="w-full">
    <!-- Header Section with Back Button -->
    <div class="mb-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <!-- Left: Title Section with Back Button -->
            <div class="flex items-start gap-4">
                @if (ShowBackButton)
                {
                    <button @onclick="HandleBack"
                            class="mt-1 p-2 bg-white border border-gray-300 hover:bg-gray-50 rounded-lg text-gray-700 transition-all duration-200 flex-shrink-0">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                    </button>
                }
                <div>
                    <h2 class="text-2xl font-bold text-gray-900">@Title</h2>
                    @if (!string.IsNullOrEmpty(Description))
                    {
                        <p class="text-sm text-gray-600 mt-1">@Description</p>
                    }
                    @if (!string.IsNullOrEmpty(Subtitle))
                    {
                        <p class="text-xs text-gray-500 mt-1">@Subtitle</p>
                    }
                </div>
            </div>

            <!-- Right: Action Buttons -->
            <div class="flex items-center gap-2 flex-wrap">
                @if (ShowRefreshButton)
                {
                    <button @onclick="HandleRefresh"
                            disabled="@IsLoading"
                            class="px-4 py-2 bg-white border border-gray-300 hover:bg-gray-50 rounded-lg text-sm font-medium text-gray-700 transition-all duration-200 flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                        <svg class="w-4 h-4 @(IsLoading ? "animate-spin" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                        </svg>
                        <span>Refresh</span>
                    </button>
                }
                @if (OnEdit.HasDelegate)
                {
                    <button @onclick="HandleEdit"
                            disabled="@IsLoading"
                            class="px-4 py-2 bg-white border border-gray-300 hover:bg-blue-50 hover:border-blue-300 rounded-lg text-sm font-medium text-gray-700 hover:text-blue-600 transition-all duration-200 flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                        <span>Edit</span>
                    </button>
                }
                @if (OnDelete.HasDelegate)
                {
                    <button @onclick="HandleDelete"
                            disabled="@IsLoading"
                            class="px-4 py-2 bg-white border border-red-300 hover:bg-red-50 rounded-lg text-sm font-medium text-red-600 hover:text-red-700 transition-all duration-200 flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                        <span>Delete</span>
                    </button>
                }
                @ActionButtons
            </div>
        </div>
    </div>

    <!-- Tab Navigation (Optional) -->
    @if (Tabs != null && Tabs.Any())
    {
        <div class="mb-6 border-b border-gray-200">
            <nav class="flex gap-6">
                @foreach (var tab in Tabs)
                {
                    <button @onclick="() => HandleTabChange(tab.Id)"
                            class="@GetTabClass(tab.Id) relative pb-3 px-1 text-sm font-medium transition-all duration-200">
                        @tab.Label
                        @if (tab.Id == ActiveTab)
                        {
                            <span class="absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-blue-600 to-indigo-600"></span>
                        }
                    </button>
                }
            </nav>
        </div>
    }

    <!-- Error Message -->
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="mb-6 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg flex items-start gap-3">
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div class="flex-1">
                <p class="text-sm font-medium">Error</p>
                <p class="text-sm mt-1">@ErrorMessage</p>
            </div>
        </div>
    }

    <!-- Loading State -->
    @if (IsLoading)
    {
        <div class="flex items-center justify-center py-12">
            <div class="text-center">
                <div class="inline-block animate-spin rounded-full h-12 w-12 border-4 border-gray-200 border-t-blue-600"></div>
                <p class="mt-4 text-sm text-gray-600">Loading...</p>
            </div>
        </div>
    }
    else
    {
        <!-- Main Content -->
        <div class="space-y-6">
            @ChildContent
        </div>
    }
</div>

@code {
    // Required Parameters
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;

    // Optional Parameters
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public bool IsLoading { get; set; } = false;
    [Parameter] public string ErrorMessage { get; set; } = string.Empty;

    // Navigation
    [Parameter] public bool ShowBackButton { get; set; } = true;
    [Parameter] public string? BackUrl { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    // Action Buttons
    [Parameter] public bool ShowRefreshButton { get; set; } = true;
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public RenderFragment? ActionButtons { get; set; }

    // Tab Navigation
    [Parameter] public List<TabItem>? Tabs { get; set; }
    [Parameter] public string ActiveTab { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> OnTabChanged { get; set; }

    // Event Handlers
    private async Task HandleBack()
    {
        if (OnBack.HasDelegate)
        {
            await OnBack.InvokeAsync();
        }
        else if (!string.IsNullOrEmpty(BackUrl))
        {
            Navigation.NavigateTo(BackUrl);
        }
        else
        {
            Navigation.NavigateTo("/");
        }
    }

    private async Task HandleRefresh()
    {
        if (OnRefresh.HasDelegate)
        {
            await OnRefresh.InvokeAsync();
        }
    }

    private async Task HandleEdit()
    {
        if (OnEdit.HasDelegate)
        {
            await OnEdit.InvokeAsync();
        }
    }

    private async Task HandleDelete()
    {
        if (OnDelete.HasDelegate)
        {
            await OnDelete.InvokeAsync();
        }
    }

    private async Task HandleTabChange(string tabId)
    {
        if (OnTabChanged.HasDelegate)
        {
            await OnTabChanged.InvokeAsync(tabId);
        }
    }

    private string GetTabClass(string tabId)
    {
        return tabId == ActiveTab
            ? "text-blue-600 border-blue-600"
            : "text-gray-600 hover:text-gray-900 border-transparent";
    }

    // Tab Item Model
    public class TabItem
    {
        public string Id { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
    }
}
